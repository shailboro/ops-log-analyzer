# LLM (required for live analysis)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# API
API_BASE_URL=http://localhost:8000
MAX_LOG_BYTES=2097152

# Slack (optional — mock mode when unset)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0123456789

# JIRA (optional — mock mode when unset)
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-api-token
# JIRA_PROJECT_KEY=OPS

# Email (optional — mock mode when unset)
# RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM=ops-alerts@example.com
# EMAIL_TO=team@example.com

# RAG with Pinecone (optional — RAG skipped when unset)
# Get Pinecone API key from https://www.pinecone.io
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_INDEX_NAME=ops-log-analyzer
# PINECONE_ENVIRONMENT=us-east-1

# LangSmith (optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...
# LANGCHAIN_PROJECT=ops-log-analyzer
